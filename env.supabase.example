# Copia a .env local o exporta en tu shell / plataforma de despliegue.
# NO subas contraseñas al repositorio.

SPRING_PROFILES_ACTIVE=supabase

# Conexión directa (puede fallar con UnknownHost si solo hay IPv6 y tu red/Java usa IPv4)
SUPABASE_DB_HOST=db.fnvbgsoaydqnqwkzzjrs.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=

# Alternativa: URL JDBC completa del panel → Database → Connection pooling → Session mode (copiar host/puerto y añadir ?sslmode=require)
# Usuario pooler suele ser: postgres.fnvbgsoaydqnqwkzzjrs
# SUPABASE_JDBC_URL=jdbc:postgresql://aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require
# SUPABASE_DB_USER=postgres.fnvbgsoaydqnqwkzzjrs

# Si resuelve DNS pero falla por IPv4/IPv6: MAVEN_OPTS=-Djava.net.preferIPv6Addresses=true

# JWT en producción (mínimo 256 bits)
APP_JWT_SECRET=

# Asistente de chat (Groq) — solo servidor; no exponer al frontend
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# Solo si el frontend usa el cliente JS de Supabase (no necesario para Spring JDBC)
# PUBLIC_SUPABASE_URL=https://fnvbgsoaydqnqwkzzjrs.supabase.co
# PUBLIC_SUPABASE_ANON_KEY=
